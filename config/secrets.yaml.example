# secrets.yaml — sensitive values referenced with !secret
#
# DO NOT commit this file. It is listed in .gitignore.
# Fill in your real values here after cloning the repo.
# Each key corresponds to a !secret reference in configuration.yaml
# or integration files.

ha_external_url: "https://yourdomain.com"
ha_internal_url: "http://<qnap-ip>:8123"

# Samsung SmartThings Personal Access Token
smartthings_token: "REPLACE_ME"

# Google Home OAuth
google_project_id: "REPLACE_ME"
google_oauth_client_id: "homeassistant"
google_oauth_client_secret: "REPLACE_ME"

# VELUX account
velux_username: "REPLACE_ME"
velux_password: "REPLACE_ME"

# LG ThinQ
lg_username: "REPLACE_ME"
lg_password: "REPLACE_ME"

# Vivax LocalTuya (Path A)
vivax_device_id: "REPLACE_ME"
vivax_local_key: "REPLACE_ME"
vivax_host: "192.168.1.XXX"

# Govee cloud API key (fallback only)
govee_api_key: "REPLACE_ME"
