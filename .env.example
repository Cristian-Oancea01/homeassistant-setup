# ============================================================
# Home Assistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is NEVER committed to git.
# ============================================================

# --- Core ---
HA_CONFIG_PATH=/share/homeassistant/config   # Path on QNAP NAS where config is stored
TZ=Europe/Your_Timezone                       # Your timezone (TZ database name)
HA_EXTERNAL_URL=https://yourdomain.com        # Your public HTTPS domain
HA_INTERNAL_URL=http://<qnap-ip>:8123         # QNAP LAN IP + HA port

# --- Govee (Cloud fallback — only if LAN control not available) ---
GOVEE_API_KEY=

# --- Samsung SmartThings ---
SMARTTHINGS_TOKEN=

# --- LG ThinQ ---
LG_THINQ_USERNAME=
LG_THINQ_PASSWORD=
LG_THINQ_REGION=EU                           # Region where LG account was created (EU, US, etc.)

# --- VELUX ---
VELUX_USERNAME=
VELUX_PASSWORD=

# --- Vivax (Tuya path — LocalTuya) ---
VIVAX_TUYA_DEVICE_ID=
VIVAX_TUYA_LOCAL_KEY=
VIVAX_TUYA_HOST=                             # LAN IP of the Vivax AC

# --- Google Home (Manual OAuth) ---
GOOGLE_PROJECT_ID=                           # Google Cloud project ID
GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME
GOOGLE_OAUTH_CLIENT_SECRET=                  # Long random string you set in Actions on Google

# --- Konfortvent entity IDs ---
# These are the actual entity IDs from your existing Konfortvent integration.
# Check Settings → Developer Tools → States to find them.
KONFORTVENT_FAN_ENTITY=fan.konfortvent
KONFORTVENT_MODE_ENTITY=select.konfortvent_mode
KONFORTVENT_TEMP_SUPPLY_ENTITY=sensor.konfortvent_temperature_supply
KONFORTVENT_TEMP_EXTRACT_ENTITY=sensor.konfortvent_temperature_extract
KONFORTVENT_HUMIDITY_ENTITY=sensor.konfortvent_humidity

# --- Presence (person entities for automations) ---
# Comma-separated list of person.* entity IDs
PERSON_ENTITIES=person.resident_1,person.resident_2

# --- Outdoor temperature sensor (any integration that provides it) ---
OUTDOOR_TEMP_SENSOR=sensor.outdoor_temperature

# --- VELUX cover entity IDs (comma-separated for automation use) ---
VELUX_COVER_LIVING_ROOM=cover.velux_living_room
VELUX_COVER_BEDROOM=cover.velux_bedroom
VELUX_COVER_KITCHEN=cover.velux_kitchen
VELUX_COVER_OFFICE=cover.velux_office

# --- AC climate entity IDs ---
AC_SAMSUNG_ENTITY=climate.samsung_ac
AC_LG_ENTITY=climate.lg_ac
AC_VIVAX_ENTITY=climate.vivax_ac

# --- Hue motion sensor entity IDs ---
HUE_MOTION_LIVING_ROOM=binary_sensor.hue_motion_living_room
HUE_LUX_LIVING_ROOM=sensor.hue_motion_living_room_illuminance

# --- Window/door sensor (for AC auto-off automation) ---
WINDOW_SENSOR_LIVING_ROOM=binary_sensor.living_room_window
